# ── Required ──────────────────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=your_github_username

# ── AI Backend ────────────────────────────────────────────────
# claude | codex  (default: claude)
AI_BACKEND=claude

# Claude CLI path (leave as 'claude' if it's on PATH)
CLAUDE_CMD=claude
CLAUDE_ARGS=-p -

# Codex CLI path (leave as 'codex' if it's on PATH)
# CODEX_CMD=codex
# CODEX_ARGS=exec --skip-git-repo-check -s read-only -
# CODEX_HOME_OVERRIDE=.codex-home

# ── Notifications (optional) ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ROVER_NOTIFY_TRANSPORT=openclaw
# OPENCLAW_CMD=openclaw
# OPENCLAW_NOTIFY_CHANNEL=telegram
# OPENCLAW_NOTIFY_TARGET=-1001234567890
# OPENCLAW_NOTIFY_ACCOUNT=
# OPENCLAW_NOTIFY_THREAD_ID=
# ROVER_NOTIFY_PROGRESS=false
# ROVER_NOTIFY_INTERVAL_SECONDS=60
# ROVER_NOTIFY_STALL_SECONDS=300
# ROVER_NOTIFY_ONLY_ON_CHANGE=true
# ROVER_NOTIFY_ON_EVENT_TYPES=started,repo_selected,stage,patch_generated,pr_submitted,completed,failed,stalled

# ── Contribution targeting ────────────────────────────────────
CONTRIB_AUTORUN_ARGS=--contrib --1
CONTRIB_LANE=devtools
# Available presets: general, crypto, devtools, frontend, data, infra, ml, docs

# Override preset keywords (comma-separated)
# CONTRIB_TOPIC_KEYWORDS=ai,agent,llm,mcp,claude
# CONTRIB_SEARCH_QUERIES=ai agent tools python,llm agent framework

# ── Repo filters ──────────────────────────────────────────────
PR_MIN_STARS=300
PR_MAX_STARS=6000
PR_MAX_PUSHED_DAYS=45
PR_MIN_OPEN_ISSUES=1
PR_MIN_FORKS=20
PR_COUNT=1

# Targeted repo breadth controls
PR_TARGETED_MAX_TOTAL_FILES=500
PR_TARGETED_MAX_PY_FILES=300
PR_TARGETED_ALLOW_BROAD=false

# ── Contribution behavior ─────────────────────────────────────
# Set to 'false' to disable dep version bumps entirely
# Default: true (but only used as fallback when AI finds nothing)
# ENABLE_DEP_UPDATE=true

# ── Advanced (optional) ───────────────────────────────────────
# ENABLE_SELF_CRITIQUE=false
# CONTRIB_FIRST_PR_MODE=false
# PR_MAX_PATCH_LINES=200
# PR_MAX_TOUCHED_FILES=3
# REPO_COOLDOWN_DAYS=30
